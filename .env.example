DB_HOST=mongodb+srv://<username>:<password>@cluster0.mongodb.net/taskpro?retryWrites=true&w=majority
ACCESS_TOKEN_KEY=your_access_token_secret
REFRESH_TOKEN_KEY=your_refresh_token_secret
JWT_SECRET=your_email_confirmation_secret

# Cloudinary credentials for avatar/background storage
CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET_KEY=your_api_secret
CLOUDINARY_URL=your_cloudinary_url

# Nodemailer credentials for help/confirmation emails
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
PORT=5000

# Keep-alive: URL of this server on Render (prevents free-tier cold starts)
SERVER_URL=https://your-app-name.onrender.com
